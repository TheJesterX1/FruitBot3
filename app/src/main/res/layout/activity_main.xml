<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D14"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="40dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🍉"
                android:textSize="64sp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FRUIT BOT"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:letterSpacing="0.2"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Floating overlay auto-slicer"
                android:textSize="13sp"
                android:textColor="#55556A"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Step 1: Accessibility -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card"
            android:padding="18dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="1"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/circle_red"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accessibility Service"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lets the bot swipe the screen"
                        android:textSize="12sp"
                        android:textColor="#55556A"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/badge1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PENDING"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnStep1"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Open Accessibility Settings"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:backgroundTint="#1C1C2E"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>

        <!-- Step 2: Overlay -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card"
            android:padding="18dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="2"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/circle_red"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Overlay Permission"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shows the floating button over apps"
                        android:textSize="12sp"
                        android:textColor="#55556A"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/badge2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PENDING"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnStep2"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Grant Overlay Permission"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:backgroundTint="#1C1C2E"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>

        <!-- Step 3: Screen Capture -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card"
            android:padding="18dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:text="3"
                    android:gravity="center"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/circle_red"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Screen Capture"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lets the bot see fruits on screen"
                        android:textSize="12sp"
                        android:textColor="#55556A"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/badge3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PENDING"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#FF9800"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnStep3"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="Grant Screen Capture"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:backgroundTint="#1C1C2E"
                style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>

        <!-- Launch button -->
        <Button
            android:id="@+id/btnLaunch"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="🍉  LAUNCH OVERLAY"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#FF4444"
            android:enabled="false"
            android:alpha="0.4"
            android:layout_marginBottom="14dp"
            style="@style/Widget.MaterialComponents.Button"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="After launching, a floating 🍉 bubble appears. Open Fruit Ninja, then tap the bubble to start slicing. Tap again to stop. Drag it anywhere."
            android:textSize="12sp"
            android:textColor="#44445A"
            android:gravity="center"
            android:lineSpacingMultiplier="1.5"
            android:layout_marginBottom="40dp"/>

    </LinearLayout>
</ScrollView>
